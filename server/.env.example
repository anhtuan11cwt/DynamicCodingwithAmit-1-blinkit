PORT=8080
FRONTEND_URL=http://localhost:5173
MONGODB_URI=your_mongodb_uri_here

# Gmail SMTP (nodemailer) — dùng App Password 16 ký tự
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password_here

# JWT secrets
SECRET_KEY_ACCESS_TOKEN=your_access_token_secret_here
SECRET_KEY_REFRESH_TOKEN=your_refresh_token_secret_here

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name_here
CLOUDINARY_API_KEY=your_api_key_here
CLOUDINARY_API_SECRET_KEY=your_api_secret_here

# Stripe
STRIPE_SECRET_KEY=your_stripe_secret_key_here
